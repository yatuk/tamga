direction: right

app: "Your App"
proxy: "Tamga Proxy"
scanner: "Scanner\nPipeline"
analyzer: "Analyzer\n(Python)"
policy: "Policy\nEngine"
llm: "LLM Provider"
db: "PostgreSQL"

app -> proxy: "1. POST /v1/messages" {
  style.stroke: "#3b82f6"
}

proxy -> scanner: "2. Inline scan (3-5ms)"

scanner -> analyzer: "3. Deep scan (if uncertain)" {
  style.stroke-dash: 3
  style.font-size: 11
}

scanner -> policy: "4. Evaluate"

policy -> llm: "5a. PASS / REDACT" {
  style.stroke: "#14b8a6"
}

policy -> app: "5b. BLOCK 403" {
  style.stroke: "#ef4444"
}

llm -> proxy: "6. Provider response"
proxy -> scanner: "7. Output scan"
proxy -> app: "8. 200 OK + headers"

proxy -> db: "9. Audit log (batched)" {
  style.stroke-dash: 2
  style.font-size: 11
}
