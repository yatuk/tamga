# ============================================
# TAMGA — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control.
# ============================================

# --- Required Secrets (changeme in production!) ---
# Generate: openssl rand -hex 32
TAMGA_ADMIN_KEY=changeme-in-production
POSTGRES_PASSWORD=changeme-in-production
REDIS_PASSWORD=changeme-in-production

# --- Go Proxy ---
TAMGA_PROXY_PORT=8443
TAMGA_POLICY_PATH=./tamga-policy.yaml
TAMGA_ANALYZER_URL=http://localhost:8444
TAMGA_DB_URL=postgresql://tamga:${POSTGRES_PASSWORD}@localhost:5432/tamga
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
TAMGA_CORS_ORIGIN=http://localhost:3000

# Demo / security hardening
TAMGA_MAX_BODY_BYTES=1048576
TAMGA_MOCK_UPSTREAM=false
TAMGA_OTEL_SAMPLE_RATE=0.05

# --- Python Analyzer ---
TAMGA_ANALYZER_PORT=8444
# Use real API keys in production — these placeholders are intentionally invalid
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME_WITH_YOUR_KEY
OPENAI_API_KEY=sk-REPLACE_ME_WITH_YOUR_KEY
DATABASE_URL=postgresql://tamga:${POSTGRES_PASSWORD}@localhost:5432/tamga

# --- Next.js Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8443
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# --- Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/WITH_REAL_URL

# --- Marketing lead capture (/contact form) ---
# Optional hCaptcha: widget is rendered when the public sitekey is set;
# siteverify is only enforced when HCAPTCHA_SECRET is also set. Leave
# both blank in dev.
NEXT_PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=
TAMGA_LEADS_WEBHOOK=

# --- TLS (production only) ---
# TAMGA_TLS_CERT=/path/to/cert.pem
# TAMGA_TLS_KEY=/path/to/key.pem
# TAMGA_MTLS_CLIENT_CA=/path/to/ca.pem
