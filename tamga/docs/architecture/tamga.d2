# Tamga Architecture Diagram
# Rendered: docs/architecture/tamga.svg

direction: down

# ===== STYLES =====
classes: {
  client: {
    shape: rectangle
    style: {
      fill: "#1f2937"
      stroke: "#374151"
      stroke-width: 1
      font-color: "#f9fafb"
      border-radius: 4
    }
  }
  proxy: {
    shape: rectangle
    style: {
      fill: "#1e3a5f"
      stroke: "#3b82f6"
      stroke-width: 2
      font-color: "#dbeafe"
      border-radius: 4
      bold: true
    }
  }
  scanner: {
    shape: rectangle
    style: {
      fill: "#0d3a3a"
      stroke: "#14b8a6"
      stroke-width: 1
      font-color: "#ccfbf1"
      border-radius: 4
    }
  }
  provider: {
    shape: rectangle
    style: {
      fill: "#1f2937"
      stroke: "#6b7280"
      stroke-width: 1
      font-color: "#e5e7eb"
      border-radius: 4
    }
  }
  data: {
    shape: cylinder
    style: {
      fill: "#2d1b4e"
      stroke: "#a855f7"
      stroke-width: 1
      font-color: "#e9d5ff"
    }
  }
  observability: {
    shape: rectangle
    style: {
      fill: "#2d1b4e"
      stroke: "#a855f7"
      stroke-width: 1
      font-color: "#e9d5ff"
      border-radius: 4
    }
  }
  management: {
    shape: rectangle
    style: {
      fill: "#3a2d0a"
      stroke: "#f59e0b"
      stroke-width: 1
      font-color: "#fef3c7"
      border-radius: 4
    }
  }
}

# ===== CLIENT LAYER =====
client: {
  label: "Client"
  app: "Your application\nHTTPS · port 8443" {
    class: client
  }
}

# ===== EDGE / PROXY =====
proxy: "Tamga Proxy" {
  class: proxy

  core: "Go · port 8443\nauth · rate limit · routing" {
    class: proxy
  }

  policy: "Policy engine\nYAML · hot-reload" {
    class: proxy
  }

  cb: "Circuit breaker\nprovider pool" {
    class: proxy
  }

  core -> policy
  policy -> cb
}

# ===== INSPECTION LAYER =====
inspection: "Inspection" {
  scanners: "Scanner pipeline\n7 inline scanners\nPII · secrets · injection\njailbreak · moderation" {
    class: scanner
  }

  analyzer: "Analyzer service\nPython · Presidio NER\nLLM-as-judge (Claude Haiku)" {
    class: scanner
  }

  scanners -> analyzer: "deep scan\ngRPC · async" {
    style.stroke-dash: 3
    style.font-size: 11
  }
}

# ===== EGRESS / LLM PROVIDERS =====
providers: "LLM Providers" {
  openai: "OpenAI" { class: provider }
  anthropic: "Anthropic" { class: provider }
  azure: "Azure · Vertex" { class: provider }
  bedrock: "Bedrock · Local" { class: provider }
}

# ===== DATA LAYER =====
data: "Data & Observability" {
  postgres: "PostgreSQL\naudit · events · pricing" {
    class: data
  }
  redis: "Redis\nrate limit · cache" {
    class: data
  }
  otel: "OTEL + Jaeger\ntraces · metrics" {
    class: observability
  }
  siem: "SIEM webhook\nSplunk · Sentinel" {
    class: observability
  }
}

# ===== MANAGEMENT PLANE =====
management: "Management Plane" {
  dashboard: "Dashboard\nNext.js · SOC console\nport 3000" {
    class: management
  }

  admin: "Admin API\nREST · policies · keys\naudit · health" {
    class: management
  }

  dashboard -> admin: "REST"
}

# ===== CONNECTIONS =====

# Client → Proxy
client.app -> proxy.core: "HTTPS"

# Proxy → Inspection
proxy.core -> inspection.scanners: "scan + policy"

# Proxy → Providers (fan-out)
proxy.cb -> providers.openai: "pass"
proxy.cb -> providers.anthropic: "pass"
proxy.cb -> providers.azure: "pass"
proxy.cb -> providers.bedrock: "pass"

# Proxy → Data
proxy.core -> data.postgres: "audit" {
  style.stroke-dash: 2
}
proxy.core -> data.redis: "rate limit" {
  style.stroke-dash: 2
}
proxy.core -> data.otel: "telemetry" {
  style.stroke-dash: 2
}
proxy.core -> data.siem: "events" {
  style.stroke-dash: 2
}

# Management → Proxy
management.admin -> proxy.core: "admin API" {
  style.stroke-dash: 3
}
management.dashboard -> data.postgres: "read events" {
  style.stroke-dash: 3
}
